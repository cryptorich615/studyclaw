# StudyClaw Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL="postgresql://studyclaw:YOUR_PASSWORD@db:5432/studyclaw"
DB_PASSWORD=change_this_password

# JWT
JWT_SECRET=super_secure_random_string_change_this

# OpenClaw (no branding to students)
OPENCLAW_URL=http://openclaw:8080
OPENCLAW_TOKEN=your_openclaw_token_here

# Admin (for Dixie system queries)
ADMIN_KEY=your_admin_key_here

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Email (for notifications)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
